{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information and role in the platform",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique Firebase Auth identifier of the user"
        },
        "fullName": {
          "type": "string",
          "description": "User's full name"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User's email address"
        },
        "photoURL": {
          "type": "string",
          "description": "Profile picture URL"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of profile creation"
        },
        "role": {
          "type": "string",
          "enum": ["user", "admin"],
          "description": "System privilege role assigned to user"
        },
        "disabled": {
          "type": "boolean",
          "description": "Whether the user account is suspended/disabled"
        }
      },
      "required": ["uid", "fullName", "email", "createdAt", "role"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "The collection of user accounts and profile documents"
    }
  }
}
