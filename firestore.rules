rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Is Signed In
    function isSignedIn() {
      return request.auth != null;
    }

    // Is Admin
    function isBootstrapAdmin() {
      return request.auth.token.email == 'bouallimohamed8@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validate User Document
    function isValidUser(data) {
      return data.uid is string &&
             data.fullName is string &&
             data.fullName.size() <= 200 &&
             data.email is string &&
             data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             (!data.keys().hasAll(['disabled']) || data.disabled is bool);
    }

    // Validate Navigation History Log
    function isValidHistory(data) {
      return data.id is string &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.companionId is string &&
             data.companionNameAr is string &&
             data.companionNameEn is string &&
             data.viewedAt is string;
    }

    // Validate Custom Study Note
    function isValidNote(data) {
      return data.id is string &&
             data.userId is string &&
             data.userId == request.auth.uid &&
             data.content is string &&
             data.content.size() <= 8192 &&
             (!data.keys().hasAll(['companionId']) || data.companionId is string) &&
             (!data.keys().hasAll(['companionNameAr']) || data.companionNameAr is string) &&
             (!data.keys().hasAll(['companionNameEn']) || data.companionNameEn is string) &&
             (!data.keys().hasAll(['title']) || (data.title is string && data.title.size() <= 200)) &&
             data.createdAt is string &&
             (!data.keys().hasAll(['updatedAt']) || data.updatedAt is string);
    }

    // Validate YouTube Video Link Resource
    function isValidVideo(data) {
      return data.id is string &&
             data.companionId is string &&
             data.titleAr is string &&
             data.titleAr.size() <= 200 &&
             (!data.keys().hasAll(['titleFr']) || (data.titleFr is string && data.titleFr.size() <= 200)) &&
             data.youtubeUrl is string &&
             data.youtubeUrl.size() <= 1024 &&
             data.createdAt is string &&
             (!data.keys().hasAll(['addedBy']) || data.addedBy is string);
    }

    // Global videos collection authorization
    match /videos/{videoId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isAdmin() && isValidVideo(request.resource.data);
      allow delete: if isSignedIn() && isAdmin();
    }

    // Users resource authorization
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'user' && (!request.resource.data.keys().hasAll(['disabled']) || request.resource.data.disabled == false);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          isValidUser(request.resource.data) &&
          request.resource.data.role == resource.data.role &&
          (!request.resource.data.keys().hasAll(['disabled']) || request.resource.data.disabled == resource.data.disabled) &&
          (request.resource.data.uid == resource.data.uid)
        )
      );
      allow delete: if isAdmin();

      // Nested History Log Subcollection
      match /history/{historyId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidHistory(request.resource.data);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      // Nested Personal Notes Subcollection
      match /notes/{noteId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn() && request.auth.uid == userId && isValidNote(request.resource.data);
        allow update: if isSignedIn() && request.auth.uid == userId && isValidNote(request.resource.data) && request.resource.data.userId == resource.data.userId && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
