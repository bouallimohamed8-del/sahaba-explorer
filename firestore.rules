rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Is Signed In
    function isSignedIn() {
      return request.auth != null;
    }

    // Is Admin
    function isBootstrapAdmin() {
      return request.auth.token.email == 'bouallimohamed8@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Validate User Document
    function isValidUser(data) {
      return data.uid is string &&
             data.fullName is string &&
             data.fullName.size() <= 200 &&
             data.email is string &&
             data.email.size() <= 256 &&
             data.role in ['user', 'admin'] &&
             (!data.keys().hasAll(['disabled']) || data.disabled is bool);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(request.resource.data) && request.resource.data.role == 'user' && (!request.resource.data.keys().hasAll(['disabled']) || request.resource.data.disabled == false);
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          isValidUser(request.resource.data) &&
          request.resource.data.role == resource.data.role &&
          (!request.resource.data.keys().hasAll(['disabled']) || request.resource.data.disabled == resource.data.disabled) &&
          (request.resource.data.uid == resource.data.uid)
        )
      );
      allow delete: if isAdmin();
    }
  }
}
